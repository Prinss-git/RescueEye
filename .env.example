# ============================================================
# RescueEye — Root Environment Variables Reference
# Copy relevant sections to each service's own .env file.
# NEVER commit real values to version control.
# ============================================================

# ── FastAPI (api/.env) ──────────────────────────────────────
# Path to the simulated drone MP4 feed (optional — synthetic fallback if absent)
DRONE_FEED_PATH=/feeds/simulation/odette_thermal.mp4

# Paths to custom-trained YOLOv8 weights (optional — COCO pretrained fallback)
VICTIM_MODEL_PATH=./models/victim_best.pt
DAMAGE_MODEL_PATH=./models/damage_best.pt

# Detection thresholds
CONFIDENCE_THRESHOLD=0.40
INCIDENT_CONF_MIN=0.75
LATENCY_WARN_MS=3000

# Bridge to Node.js server (for auto-incident creation)
NODE_SERVER_URL=http://localhost:3001

# CORS allowed origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:5173

# ── Node.js Server (server/.env) ───────────────────────────
# Firebase service account credentials (path to JSON file)
FIREBASE_CREDENTIAL_PATH=/path/to/serviceAccountKey.json

# Or provide individual Firebase fields (for cloud deployment)
FIREBASE_PROJECT_ID=rescueeye-xxxx
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxx@rescueeye-xxxx.iam.gserviceaccount.com

# Server port
PORT=3001

# CORS allowed origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:5173

# ── Frontend (frontend/.env) ────────────────────────────────
# Firebase Web SDK config (optional — no-op if absent)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Backend URLs (defaults match Vite proxy for local dev)
# Override for production deployment
# VITE_API_URL=https://rescueeye-api.onrender.com
# VITE_SERVER_URL=https://rescueeye-server.onrender.com
