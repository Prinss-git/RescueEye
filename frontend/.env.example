# RescueEye Frontend — Environment Variables
# Copy this file to .env and fill in your values.

# ── Firebase (optional — app works without it in demo mode) ───────────────────
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ── Backend URLs (defaults work for local dev) ────────────────────────────────
# Vite proxies /api → http://localhost:8000 and /server → http://localhost:3001
# For production deployments (e.g. Render.com), set these to the deployed URLs:
# VITE_API_URL=https://your-api.onrender.com
# VITE_SERVER_URL=https://your-server.onrender.com
