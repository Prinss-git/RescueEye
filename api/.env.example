HOST=0.0.0.0
PORT=8000

# ── Drone feed ────────────────────────────────────────────────────────────────
# Path to local MP4 for the simulated drone feed.
# If not set or file not found, the API uses a synthetic animated frame.
DRONE_FEED_PATH=C:/path/to/your/drone_footage.mp4

# Frames per second extracted from the MP4 (and sent to the MJPEG stream).
FRAME_RATE=1

# ── AI models ─────────────────────────────────────────────────────────────────
# Victim detection — custom-trained weights (Phase 3 output).
# Falls back to yolov8n.pt (COCO pretrained) if file does not exist.
VICTIM_MODEL_PATH=models/victim_best.pt

# Damage classification — custom-trained weights (Phase 3 output).
# Falls back to yolov8n-cls.pt (COCO pretrained) if file does not exist.
DAMAGE_MODEL_PATH=models/damage_best.pt

# Legacy single-model path (Phase 2 compat — ignored when above paths are set)
MODEL_PATH=yolov8n.pt

# Detection confidence threshold (0.0 – 1.0)
CONFIDENCE_THRESHOLD=0.40

# Log a console warning when inference exceeds this many milliseconds
LATENCY_WARN_MS=3000

# ── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173
